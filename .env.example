# Copy this file to .env.local and fill in real values when you connect services.
# Do NOT commit .env.local to git.

# Supabase (add when you set up the database)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Paystack (add when you set up payments)
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# PAYSTACK_SECRET_KEY=

# App URL
# NEXT_PUBLIC_APP_URL=http://localhost:3000
